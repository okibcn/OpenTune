{
  "name": "Android Dev - OpenTune",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "postCreateCommand": "/bin/bash .devcontainer/setup.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "mathiasfrohlich.Kotlin",
        "vscjava.vscode-java-pack",
        "redhat.java",
        "naco-siren.gradle-language",
        "vscjava.vscode-gradle"
      ],
      "settings": {
        "java.jdt.ls.java.home": "/opt/java/21",
        "java.configuration.runtimes": [
          {
            "name": "JavaSE-21",
            "path": "/opt/java/21",
            "default": true
          }
        ]
      }
    }
  },
  "remoteEnv": {
    "JAVA_HOME": "/opt/java/21",
    "ANDROID_HOME": "/opt/android-sdk",
    "ANDROID_SDK_ROOT": "/opt/android-sdk",
    "PATH": "${PATH}:/opt/java/21/bin:/opt/android-sdk/cmdline-tools/latest/bin:/opt/android-sdk/platform-tools:/opt/android-sdk/build-tools/34.0.0"
  }
}
